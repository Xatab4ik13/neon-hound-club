# Server
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Public origins (CORS + cookie domain)
FRONTEND_ORIGIN=https://hhr.pro
COOKIE_DOMAIN=.hhr.pro

# Postgres (внутри docker-compose host=postgres)
DATABASE_URL=postgres://hellhound:CHANGE_ME@postgres:5432/hellhound

# Auth
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
SESSION_MAX_AGE_DAYS=30

# MinIO (S3)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=hellhound
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=hellhound-media
S3_PUBLIC_URL=https://api.hhr.pro/media

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Hellhound <no-reply@hhr.pro>

# Hell AI (Lovable AI Gateway)
LOVABLE_API_KEY=

# CDEK
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
