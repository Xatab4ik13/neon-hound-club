# Server
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Public origins (CORS + cookie domain)
FRONTEND_ORIGIN=https://hhr.pro
COOKIE_DOMAIN=.hhr.pro

# Postgres (внутри docker-compose host=postgres)
DATABASE_URL=postgres://hellhound:CHANGE_ME@postgres:5432/hellhound

# Auth
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
SESSION_MAX_AGE_DAYS=30

# MinIO (S3)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=hellhound
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=hellhound-media
S3_PUBLIC_URL=https://api.hhr.pro/media

# Email
MAIL_FROM="HELLHOUND Racing <no-reply@hhr.pro>"
MAIL_PROVIDER=auto
MAIL_HTTP_TIMEOUT_MS=15000

# Preferred on VPS with blocked SMTP: HTTP API over 443
UNISENDER_API_KEY=
UNISENDER_BASE_URL=https://goapi.unisender.ru/ru/transactional/api/v1
RESEND_API_KEY=

# SMTP fallback
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@hhr.pro
SMTP_PASS=CHANGE_ME

# Hell AI (Lovable AI Gateway)
LOVABLE_API_KEY=

# CDEK
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
