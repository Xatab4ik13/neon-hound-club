# Скопируй в backend/.env на VPS и заполни
NODE_ENV=production
PORT=3001

# Postgres — те же значения, что в /opt/hellhound/.env (хост = host.docker.internal или IP сети)
DATABASE_URL=postgresql://hellhound:PASSWORD@host.docker.internal:5432/hellhound

# Случайная строка ≥32 символов: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# Откуда фронт ходит. Lovable превью + будущий домен.
CORS_ORIGINS=https://id-preview--684793f4-d120-461e-9357-79d82baeb567.lovable.app,https://hhr.pro,https://www.hhr.pro

# Cookie domain. На превью оставь пусто, на проде поставь .hhr.pro
COOKIE_DOMAIN=
